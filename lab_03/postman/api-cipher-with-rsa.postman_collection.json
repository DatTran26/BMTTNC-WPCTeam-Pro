        {
          "name": "RSA",
          "item": [
            {
              "name": "Generate Keys",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/rsa/generate_keys"
                }
              }
            },
            {
              "name": "Encrypt",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/rsa/encrypt"
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"message\": \"HUTECH University\",\n  \"key_type\": \"public\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "const jsonData = pm.response.json();",
                      "pm.collectionVariables.set(\"rsa_ciphertext\", jsonData.encrypted_message || jsonData.ciphertext || jsonData.encrypted_text || jsonData.result);"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Decrypt",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/rsa/decrypt"
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ciphertext\": \"{{rsa_ciphertext}}\",\n  \"key_type\": \"private\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const ciphertext = pm.collectionVariables.get(\"rsa_ciphertext\");",
                      "if (!ciphertext) {",
                      "    throw new Error(\"Run RSA / Encrypt first to set rsa_ciphertext.\");",
                      "}"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});"
                    ]
                  }
                }
              ]
            },
